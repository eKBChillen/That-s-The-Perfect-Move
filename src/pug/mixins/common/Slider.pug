mixin Slider
  .swiper-theme-container.theme-slider(data-swiper-theme-container)&attributes(attributes)
    .swiper(data-swiper!={
      autoplay: {
        delay: 6000,
        disabledOnInteraction: false
      },
      spaceBetween: 30,
      loop: true,
      slideToClickedSlide: true,
      slidesPerView: 1,
      effect: 'fade',
    })
      .swiper-wrapper
        .swiper-slide 
          img(src=`${CWD}assets/img/blog-02.jpg`, alt="")
        .swiper-slide 
          img(src=`${CWD}assets/img/blog-03.jpg`, alt="")
      .swiper-nav
        .swiper-button-next
        .swiper-button-prev