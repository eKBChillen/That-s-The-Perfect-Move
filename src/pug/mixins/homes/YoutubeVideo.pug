mixin YoutubeVideo(title) 
  +Section({
    image: `${CWD}assets/img/video-header.jpg`,
    className: 'overlay overlay-2',
    youtube: {
      videoId: 'luCYT7Qx1oA',
      mute: true,
      startSeconds: 2,
      endSeconds: 17
    }
  }, container)(
      data-zanim-timeline!={delay: 0} 
      data-zanim-trigger!='scroll' 
      class=`${title === 'classic' ? 'py-3' : 'py-0'}`
    )
    .row.py-8.flex-center(class=`${title === 'classic' ? 'min-vh-75' : 'min-vh-100'}`) 
      .col-auto.text-center 
        p.fst-italic.p-0.mb-2.text-white.fs-8.font-base(
          data-zanim-xs!={
            delay: 0.7,
            duration: 0.7,
            ease: 'Power2.easeOut',
            from: {y: 20, opacity: 0},
            to: {y: 0, opacity: 1}
          }
        ) Success Stories 

        h2.text-uppercase.text-white.mb-md-5.mb-4.fw-bolder.fs-6.fs-lg-5.ls-2.pt-1(
          data-zanim-xs!={
            delay: 0,
            duration: 1,
            ease: 'Sine.easeInOut',
            from: {letterSpacing: '0.25em', opacity: 0},
            to: {letterSpacing: '0.05em', opacity: 1}
          }
        ) start with you 

        button.btn.btn-primary.rounded-capsule.mt-3.ls-1(
          data-zanim-xs!={
            delay: 1.2,
            duration: 0.7,
            ease: 'Power2.easeOut',
            from: {y: -20, opacity: 0},
            to: {y: 0, opacity: 1}
          }
        ) Learn More
        
    +ScrollSpyButton({url: '#secondSection', offset: '400'})


mixin YoutubeVideoClassic
  .overflow-hidden
    +Section({image: `${CWD}assets/images/yt-video.jpg`, youtube: {videoId: 'NXvgDydGjy0', startSeconds: 01, endSeconds: 16}, className: "overlay bg-youtube", attrs: {"data-zanim-xs": {delay: 0.5, animation: 'zoom-out'}, "data-zanim-trigger": "scroll"}}, container).py-0.text-center.header.overflow-hidden
      .row.py-7.align-items-center
        .col 
          h5.text-white.fs-9.fs-sm-8.mb-4.text-uppercase(data-zanim-xs!={delay: 1.2}) Welcome to 
          h1.text-white.fs-6.fs-sm-4.fw-bold.ls-3.text-uppercase 
            span.d-block(data-zanim-xs!={delay:1.3}) baikal
            span.d-block(data-zanim-xs!={delay:1.4}) Liveliness 
          .text-white(data-zanim-xs!={delay:1.5}) 
            a(href="#!").fw-medium.fs-9.fs-sm-7.text-white  Retreats
            span.px-2.fs-10.d-inline-block &#9679;
            a(href="#!").fw-medium.fs-9.fs-sm-7.text-white Adventure
            span.px-2.fs-10.d-inline-block &#9679;
            a(href="#!").fw-medium.fs-9.fs-sm-7.text-white Spa
          a.btn.rounded-capsule.btn-primary.mt-5(href="#!" data-zanim-xs!={delay:1.7}) Our Story 
      +ScrollSpyButton({
        attrs: {"data-zanim-xs": {delay: 2.3}, "data-zanim-trigger": "scroll"}
      })
    #target-down
